/*
@plugin
name: Quick Transform
description: Reset position, rotation, or scale on selected nodes. Supports multi-selection and full undo.
version: 1.0.0
author: TrashBash
permissions: core, commands, context, tmd
*/

// @ Helpers

GatherSelectedNodes = function()
{
	var _all = selection_get_all();
	if (is_array(_all) and array_length(_all) > 0)
	{
		return _all;
	}

	var _single = selection_get();
	if (_single != undefined)
	{
		return [_single];
	}

	return [];
}

PollSelectedNodes = function()
{
	var _nodes = global.GatherSelectedNodes();
	if (array_length(_nodes) == 0)
	{
		return undefined;
	}
	return { nodes: _nodes };
}

// @ Commands

ResetPositionCommand = extend("TrashMD_Command", function()
{
	self.id			= "qtransform.reset_position";
	self.label		= "Reset Position";
	self.category	= "Quick Transform";
	self.undoable	= true;

	self.Poll = global.PollSelectedNodes;

	self.Execute = function(_params)
	{
		var _undoData = [];
		for (var i = 0; i < array_length(_params.nodes); i += 1)
		{
			var _node = _params.nodes[i];
			var _oldPos = node_get_position(_node);
			array_push(_undoData, { node: _node, pos: _oldPos });
			node_set_position(_node, 0, 0, 0);
		}
		SUCCESS("Reset position on " + string(array_length(_undoData)) + " node(s)");
		return _undoData;
	}

	self.Undo = function(_undoData)
	{
		for (var i = 0; i < array_length(_undoData); i += 1)
		{
			var _e = _undoData[i];
			node_set_position(_e.node, _e.pos[0], _e.pos[1], _e.pos[2]);
		}
		LOG("Undo: restored position on " + string(array_length(_undoData)) + " node(s)");
	}
});

ResetRotationCommand = extend("TrashMD_Command", function()
{
	self.id			= "qtransform.reset_rotation";
	self.label		= "Reset Rotation";
	self.category	= "Quick Transform";
	self.undoable	= true;

	self.Poll = global.PollSelectedNodes;

	self.Execute = function(_params)
	{
		var _undoData = [];
		for (var i = 0; i < array_length(_params.nodes); i += 1)
		{
			var _node = _params.nodes[i];
			var _oldRot = node_get_rotation(_node);
			array_push(_undoData, { node: _node, rot: _oldRot });
			node_set_rotation(_node, 0, 0, 0);
		}
		SUCCESS("Reset rotation on " + string(array_length(_undoData)) + " node(s)");
